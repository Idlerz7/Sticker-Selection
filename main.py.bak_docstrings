                img = torch.stack(img_objs, dim=0).to(device)
                self.clip_model.eval()
                self.all_img_embs = self.clip_model.encode_image(img)

            elif self.args.model_choice == 'use_img_id':
                img_ids = list(range(self.args.max_image_id))
