    def __init__(self, args):
        super().__init__()
        # self.tokenizer = AutoTokenizer.from_pretrained(args.pretrain_path)
        # logger.info(f"tokenizer type:{type(self.tokenizer)}")(
        self.model = Model(args)
        # special_tokens_dict = {
